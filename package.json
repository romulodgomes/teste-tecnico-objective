{
  "scripts": {
    "test": "cypress run --browser chrome",
    "test:api": "cypress run --spec cypress/api/**/*.feature --env htmlOutput=cypress/reports/api-report.html",
    "test:e2e": "cypress run --browser chrome --spec cypress/e2e/**/*.feature --env htmlOutput=cypress/reports/e2e-report.html",
    "open": "cypress open"
  },
  "dependencies": {
    "@badeball/cypress-cucumber-preprocessor": "^26.0.0",
    "@bahmutov/cypress-esbuild-preprocessor": "^2.2.8",
    "@faker-js/faker": "^10.5.0",
    "@types/node": "^26.1.1",
    "typescript": "^5.9.3"
  },
  "allowScripts": {
    "cypress@15.18.1": true,
    "esbuild@0.28.1": true
  },
  "cypress-cucumber-preprocessor": {
    "stepDefinitions": "cypress/support/stepDefinitions/**/*.{js,ts}",
    "html": {
      "enabled": true,
      "output": "cypress/reports/cucumber-report.html"
    }
  }
}
